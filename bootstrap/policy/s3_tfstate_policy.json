{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowTerraformRoleAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "${terraform_role_arn}",
          "${terraform_user_arn}"
        ]
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketAcl",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::${bucket_name}",
        "arn:aws:s3:::${bucket_name}/*"
      ]
    }
  ]
}
